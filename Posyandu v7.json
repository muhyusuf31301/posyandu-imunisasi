        "jsCode": "const body = $('POST /posyandu/ibu').first().json.body;\nconst rows = $input.all().map(i => i.json).filter(r => r && r.NIK && r.NIK !== '');\nconst exists = rows.some(r => String(r.NIK).trim() === String(body.nik).trim());\nreturn [{ json: {\n  mode:      exists ? \"update\" : \"append\",\n  NIK:       String(body.nik || \"\"),\n  Nama:      body.name      || \"\",\n  Phone:     body.phone     || \"\",\n  Alamat:    body.alamat    || \"\",\n  CreatedAt: body.createdAt || new Date().toISOString(),\n}}];"
