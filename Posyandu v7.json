    {
      "parameters": {
        "jsCode": "const body = $('POST /posyandu/anak').first().json.body;\nconst rows = $input.all().map(i => i.json).filter(r => r && r.NIK_Ibu && r.NIK_Ibu !== '' && r.NIK_Ibu !== 'NIK_Ibu');\n\nconst searchName = body.originalName || body.name;\nconst searchKey  = String(body.nikIbu).trim() + \"|\" + searchName.trim();\nconst newKey     = String(body.nikIbu).trim() + \"|\" + String(body.name).trim();\n\n// Cari row via _compositeKey yang sudah ada di sheet (dari ArrayFormula)\nconst exists = rows.some(r => \n  String(r._compositeKey || \"\").trim() === searchKey\n);\n\nlet vac = \"[]\";\ntry { vac = JSON.stringify(body.vaccines || []); } catch(e) {}\n\nreturn [{ json: {\n  mode:                exists ? \"update\" : \"append\",\n  NIK_Ibu:             String(body.nikIbu || \"\"),\n  Nama:                body.name      || \"\",\n  DOB:                 body.dob       || \"\",\n  Gender:              body.gender    || \"P\",\n  Vaccines:            vac,\n  CreatedAt:           body.createdAt || new Date().toISOString(),\n  UpdatedAt:           new Date().toISOString(),\n  _compositeKey_where: searchKey,   // untuk WHERE di Update node\n}}];"
      },
