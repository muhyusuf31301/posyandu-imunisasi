    {
      "parameters": {
        "jsCode": "let ibus = [];\nlet anak = [];\n\ntry {\n  const ibuItems = $('Read Ibu v7').all();\n  ibus = ibuItems.map(i => i.json).filter(r => r && r.NIK && String(r.NIK).trim() !== '');\n} catch(e) { ibus = []; }\n\ntry {\n  const anakItems = $('Read Anak v7').all();\n  anak = anakItems.map(i => i.json).filter(r => r && r.NIK_Ibu && String(r.NIK_Ibu).trim() !== '');\n} catch(e) { anak = []; }\n\nconst mothers = ibus.map(ibu => {\n  const children = anak\n    .filter(a => String(a.NIK_Ibu).trim() === String(ibu.NIK).trim())\n    .map(a => {\n      let vaccines = [];\n      try { vaccines = JSON.parse(a.Vaccines || '[]'); } catch(e) {}\n      return { name:a.Nama||'', dob:a.DOB||'', gender:a.Gender||'P', vaccines, createdAt:a.CreatedAt||'' };\n    });\n  return { name:ibu.Nama||'', nik:String(ibu.NIK||''), phone:ibu.Phone||'', alamat:ibu.Alamat||'', createdAt:ibu.CreatedAt||'', children };\n});\n\n// Stringify di sini supaya Respond GET tinggal pakai $json.response\nconst response = JSON.stringify({ mothers });\nreturn [{ json: { mothers, response } }];"
      },
